$display(
  dv(T, x) = C_1 => T(x) = C_1 x + C_2 \
  cases(
    reverse: #true,
    x = 0 quad T(0) = C_1 dot 0 + C_2 = T_w_1,
    x = delta quad T(delta) = C_1 delta + C_2 = T_w_2,
  ) \
  C_2 = T_w_1 \
  C_1 = (T_w_2 - T_w_1)/delta
)$

$
  T(x) = (T_w_2 - T_w_1)/delta x + T_w_1
$

$display(
  ov(q) = -lambda ov(grad)T \
  q = -lambda dv(T, x) = -lambda C_1 = lambda/delta (T_w_1 - T_w_2) \
  Delta T = T_w_1 - T_w_2
)$

$
  q = lambda/delta Delta T
$

Тепловая проводимость плоской стенки
$
  [lambda/delta] = "Вт"/(м^2 dot К)
$

Тепловое (или термическое) сопротивление
$
  R_lambda = delta/lambda space [(м^2 dot К)/"Вт"]
$

При подстановке $R_lambda$ получаем аналогию закону Ома
$
  q = (Delta T)/R_lambda <-> I = (Delta U)/R_э
$

$
  R_lambda = (Delta T)/q => q ~ I, space Delta T ~ Delta U, space R_lambda ~ R_э
$

