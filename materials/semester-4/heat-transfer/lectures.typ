      Q_L_a_1 = Q_L_lambda = Q_L_alpha_2 = Q_L = const
    $

    $display(
      cases(
        Q_L = alpha_1 (T_f_1 - T_w_1) dot 2pi r_1,
        Q_L = (pi (T_w_1 - T_w_2))/(1/(2lambda) ln r_2/r_1)
        Q_L = alpha_2 (T_f_2 - T_w_2) dot 2pi r_2,
      ) \
      Q_L (1/(2alpha_1 r_1) + 1/(2lambda) ln r_2/r_1 + 1/(2alpha_2 r_2)) = pi (T_f_1 - T_f_2)
    )$

    $
      Q_L = (pi (T_f_1 - T_f_2))/(1/(2alpha_1 r_1) + 1/(2lambda) ln r_2/r_1 + 1/(2alpha_2 r_2))
    $
  ],
)

Суммарное линейное термическое сопротивление
$
  R_L = 1/(2alpha_1 r_1) + 1/(2lambda) ln r_2/r_1 + 1/(2alpha_2 r_2) \
$

$display(
  R_L_alpha_1 = 1/(2alpha_1 r_1) \, space R_L_lambda = 1/(2lambda) ln r_2/r_1 \, space R_L_alpha_2 = 1/(2alpha_2 r_2)
)$

Линейный коэффициент теплопередачи
$
  & "Кц" = 1/R_L = 1/(1/(2alpha_1 r_1) + 1/(2lambda) ln r_2/r_1 + 1/(2alpha_2 r_2)) \
  & Q_L = pi dot "Кц" (T_f_1 - T_f_2)
$
Характеризует интенсивность передачи от одной подвижной среды к другой через однослойную цилиндрическую стенку. Численно равен количеству теплоты, проходящему через цилиндрическую стенку длиной в 1м в единицу времени от одной среды к другой при температурном напоре между ними, равному 1К.
$
  q_1 = Q/(pi d_1 L) = Q_L/(pi d_1) = "Кц"/d_1 (T_f_1 - T_f_2) \
  q_2 = Q/(pi d_2 L) = Q_L/(pi d_2) = "Кц"/d_2 (T_f_1 - T_f_2)
$

Введём понятие коэффициентов теплопередачи к единице площади $K_1$, $K_2$
$
  & K_1 = "Кц"/d_1; space K_2 = "Кц"/d_2 \
  & q_1 = K_1 (T_f_1 - T_f_2); space q_2 = K_2 (T_f_1 - T_f_2) \
  & K_1 = 1/(1/alpha_1 + d_1/(2lambda) ln d_2/d_1 + d_1/(alpha_2 d_2)) space dash "на внутренней поверхности" \
  & K_2 = 1/(d_2/(alpha_1 d_1) + d_2/(2lambda) ln d_2/d_1 + 1/alpha_2) space dash "на внешней поверхности" \
  & "Кц" = K_1 d_1 = K_2 d_2
$

=== Теплопередача через многослойную цилиндрическую стенку (Теплопроводность многослойной цилиндрической стенки с граничными условиями III рода)

#v(1em)

$
  pdv(T, tau) = 0 quad lambda_i = const quad q_v_i = 0
$

С внутренней стороны $T_f_1$ и $alpha_1$; с внешней -- $T_f_2$ и $alpha_2$

$display(
  Q_L_alpha_1 = Q_L_lambda = Q_L_alpha_2 = Q_L = const \
  cases(
    Q_L = alpha_1 (T_f_1 - T_w_1) dot 2pi r_1,
    Q_L = (pi (T_w_1 - T_w_(n-1)))/(sum_(i=1)^n (1/(2lambda_i) ln r_(i+1)/r_i)),
    ...,
    Q_L = alpha_2 (T_w_(n+1) - T_f_2) dot 2pi r_(n+1),
  )
)$

$
  Q_L = (pi (T_f_1 - T_f_2))/(1/(2alpha_1 r_1) + sum_(i=1)^n (1/(2lambda_i) ln r_(i+1)/r_i) + 1/(2alpha_2 r_(n+1)))
$

Суммарное линейное термическое сопротивление многослойной цилиндрической стенки
$
  R_L_ц = 1/(2alpha_1 r_1) + sum_(i=1)^n (1/(2lambda_i) ln r_(i+1)/r_i) + 1/(2alpha_2 r_(n+1)) space [(м dot К)/"Вт"]
$

Линейный коэффициент теплопередачи многослойной цилиндрической стенки
$
  & "Кц" = 1/R_L_ц = 1/((2alpha_1 r_1) + sum_(i=1)^n (1/(2lambda_i) ln r_(i+1)/r_i) + 1/(2alpha_2 r_(n+1))) space ["Вт"/(м dot К)] \
  & Q_L = "Кц" dot pi(T_f_1 - T_f_2)
$

Температуры на границах между слоями
$
  T_w_(i+1) = T_f - Q_L/pi (1/(2alpha_1 r_1) + sum_1^i (1/(2lambda_i) ln r_(i+1)/r_i))
$

=== Критический диаметр тепловой изоляции

