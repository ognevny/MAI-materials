  ],
  [
    $
                        x = 0 quad & T(0) = T_w_1 \
      x = sum_(i=0)^n delta_i quad & T(Sigma) = T_w_(n+1)
    $

    $display(
      q_1 = q_2 = ... = q_n = q = const \
      cases(
        q = lambda_1/delta_1 (T_w_1 - T_w_2),
        q = lambda_2/delta_2 (T_w_2 - T_w_3),
        ...,
        q = lambda_n/delta_n (T_w_n - T_w_(n+1))
      ) <=> cases(
        q delta_1/lambda_1 = T_w_1 - T_w_2,
        q delta_2/lambda_2 = T_w_2 - T_w_3,
        ...,
        q delta_n/lambda_n = T_w_n - T_w_(n+1),
      ) + \
      q (delta_1/lambda_1 + delta_2/lambda_2 + ... + delta_n/lambda_n) = T_w_1 - T_w_(n+1)
    )$
  ],
)

$
  q = (T_w_1 - T_w_(n+1))/(delta_1/lambda_1 + delta_2/lambda_2 + ... + delta_n/lambda_n)
$

Суммарное (полное) термическое сопротивление
$
  & R_Sigma_lambda = delta_1/lambda_1 + delta_2/lambda_2 + ... + delta_n/lambda_n = sum_(i=1)^n (delta/lambda)_i = sum_(i=1)^n R_lambda_i
$

Тогда тепловой поток будет записан в виде
$
  q = (T_w_1 - T_w_(n+1))/(sum_(i=1)^n (delta/lambda)_i)
$

Чем больше тангенс угла наклона зависимости $T(x)$ в каждом из слоев, тем меньше коэффициент теплопроводности. То есть если температура сильнее падает в слое, то этот слой обладает меньшим коэффициентом $lambda$.

$display(
  q = -lambda_i (dv(T, x))_i = const \
  lambda arrow.t -> (dv(T, x))_i arrow.b \
  T_w (x_i)_i = T_w_i - q x_i/delta_i
)$

=== Теплопередача через однослойную плоскую стенку (теплопроводность через плоскую стенку с граничными условиями III рода)

#v(1em)

Стенка с обеих сторон обтекается жидкостью с разной температурой.

Теплопередача -- процесс переноса теплоты от одной подвижной среды к другой среде через разделяющую их твердую стенку любой формы.

Процесс теплопередачи включает в себя три следующих процесса:
- Теплоотдачу от более нагретой среды к поверхности стенки
- Перенос теплоты теплопроводностью внутри стенки
- Теплоотдачу от поверхности стенки к менее нагретой стенке

Условия для жидкостей заданы следующие
$
  T_f_1 = const; space alpha_1 = const \
  T_f_2 = const; space alpha_2 = const
$

#grid(
  columns: (1fr, 4fr),
  column-gutter: 1em,
  [
    #figure(
      image("source-figures/lect7-5.png"),
    )
  ],
  [
    $display(
      q_alpha_1 = q_lambda = q_alpha_2 = q = const\, space q_V = 0 \
      cases(
        q = alpha_1 (T_f_1 - T_w_1),
        q = lambda/delta (T_w_1 - T_w_2),
        q = alpha_2 (T_w_2 - T_f_2),
      ) => q (1/alpha_1 + delta/lambda + 1/alpha_2) = T_f_1 - T_f_2
    )$

    $
      q = (T_f_1 - T_f_2)/(1/alpha_1 + delta/lambda + 1/alpha_2)
    $

    Суммарное термическое (тепловое) сопротивление теплопередачи плоской однослойной стенки
    $
      R_Sigma = 1/alpha_1 + delta/lambda + 1/alpha_2 = R_alpha_1 + R_lambda + R_alpha_2 \
      R_alpha = 1/alpha_1, space R_lambda = delta/lambda, space R_alpha_2 = 1/alpha_2
    $
  ],
)

Таким образом тепловой поток выражается как
$
  q = (T_f_1 - T_f_2)/R_Sigma
$

Коэффициент теплопередачи
$
  k = 1/R_Sigma = 1/(1/alpha_1 + delta/lambda + 1/alpha_2)
$

$
  q = k (T_f_1 - T_f_2) => k = q/(T_f_1 - T_f_2) space ["Вт"/(м^2 dot К)]
$

Физический смысл: $k$ численно равен количеству теплоты, которое передается через единицу поверхности плоской стенки на единицу времени при разности температур между жидкостями в один градус.

Температуры поверхности определяются следующими выражениями
$
  T_w_1 = T_f_1 - q 1/alpha_1 \
  T_w_2 = T_f_2 - q 1/alpha_2
$

=== Теплопроводность через многослойную плоскую стенку с граничными условиями III рода (теплопередача через многослойную плоскую стенку)

#v(1em)

#grid(
  columns: (1fr, 1.5fr),
  column-gutter: 1em,
  [
    #figure(
      image("source-figures/lect7-6.png"),
    )
  ],
  [
    $
      q = q_lambda_i = q_alpha_1 = q_alpha_2 = const, space q_V_i = 0
    $
    $display(
      cases(
        q = alpha_1 (T_f_1 - T_w_1),
        q = (T_w_1 - T_w_(n+1))/(sum_(i=1)^n (delta/lambda)_i),
        q = alpha_2 (T_w_(n+1) - T_f_2),
      )
    )$

    $
      q = (T_f_1 - T_f_2)/(1/alpha_1 + sum_(i=1)^n (delta/lambda)_i + 1/alpha_2)
    $

    Термическое сопротивление
    $
      R_Sigma = 1/alpha_1 + sum_(i=1)^n (delta/lambda)_i + 1/alpha_2, space R_lambda = sum_(i=1)^n (delta/lambda)_i
    $
  ],
)

Коэффициент теплопередачи
$
  k = 1/(1/alpha_1 + sum_(i=1)^n (delta/lambda)_i + 1/alpha_2) => q = k (T_f_1 - T_f_2)
$

Можно определить температуры поверхностей, ограничивающих многослойную плоскую стенку
$
  cases(
    T_w_1 = T_f_1 - q 1/alpha_1,
    T_w_(n+1) = T_f_2 + q 1/alpha_2,
  )
$

Температуры на границе любых двух слоев при граничных условиях III рода
$
  T_w_(i+1) = T_f_1 - q (1/alpha_1 + sum_(1)^i delta_i/lambda_i)
$

Значения температуры внутри каждого из слоев
$
  T(x_i) = T_w_i - q x_i/delta_i
$

=== Теплопроводность плоской стенки с граничными условиями I рода при $lambda = lambda(T)$

#v(1em)

$
  "div"(lambda ov(grad)T) = 0
$

$display(
  pdv(, x) (lambda pdv(T, x)) + pdv(, y) (cancel(lambda pdv(T, y))) + pdv(, z) (cancel(lambda pdv(T, z))) = 0 => dv(, x) (lambda pdv(T, x)) = 0
)$

Введем новую переменную
$
  dv(Phi, x) = lambda pdv(T, x)
$

$display(
  dv(Phi, x, 2) = 0 quad cases(Phi(0) = Phi_1, Phi(delta) = Phi_2) \
  Phi(x) = C_1 x + C_2 \
  C_1 = (Phi_2 - Phi_1)/delta\, space C_2 = Phi_1 \
  q = -lambda dv(T, x) = -dv(Phi, x) = (Phi_1 - Phi_2)/delta <=> integral_0^delta dv(Phi, x) dif x = integral_0^delta lambda dv(T, x) dif x <=> integral_(Phi_1)^(Phi_2) dif Phi = integral_(T_w_1)^(T_w_2) lambda dif T <=> Phi_2 - Phi_1 = integral_(T_w_1)^(T_w_2) lambda dif T <=> \ <=> Phi_1 - Phi_2 = integral_(T_w_2)^(T_w_1) lambda dif T \
  q = 1/delta integral_(T_w_2)^(T_w_1) lambda dif T
)$

$
  q = (T_w_1 - T_w_2)/delta [1/(T_w_1 - T_w_2) integral_(T_w_2)^(T_w_1) lambda dif T]
$

Среднеинтегральное значение коэффициента теплопроводности в интервале температур $[T_w_1, T_w_2]$
$
  lambda_"ср" = 1/(T_w_1 - T_w_2) integral_(T_w_2)^(T_w_1) lambda dif T
$

Тогда тепловой поток принимает вид
$
  q = lambda_"ср"/delta (T_w_1 - T_w_2)
$

Если $lambda = lambda(T)$, то вычислить q можно относительно произвольной функции с $lambda = const$ используя среднее интегральное значение коэффициента теплопроводности в интервале температур от $T_w_1$ до $T_w_2$. Этот вывод справедлив для любой геометрии стенки.

$
  & lambda = a + b T \
  & lambda_"ср" = a + b T_"ср" \
  & T_"ср" = (T_w_1 + T_w_2)/2
$

+ $b = 0$, $lambda = const$

+ $b > 0 => T arrow.t -> lambda arrow.t$, $x arrow.t -> T arrow.b -> lambda arrow.b$

  $q = -lambda dv(T, x) = const$

+ $b < 0$

=== Теплопроводность плоской стенки при наличии объемных источников тепловыделения

#v(1em)

$
  q_v != 0, space q_v = const \
  nabla^2 T + q_v/lambda = 0 <=> dv(T, x, 2) + q_v/lambda = 0
$

$display(dv(T, x) = -q_v/lambda x + C_1 => T(x) = -q_v/(2lambda) x^2 + C_1 x + C_2)$

Пусть $T_w_1 = T_w_2 = T_w$, тогда $x = delta/2$ -- ось симметрии

$display(
  evaluated(dv(T, x))_(x=delta/2) = -(q_V delta)/(2lambda) + C_1 = 0 => C_1 = (q_v delta)/(2lambda) \
  T(0) = T_w = -q_v/(2lambda) dot 0 + C_1 dot 0 = C_2 => C_2 = T_w
)$

$
  T(x) = -q_v/(2lambda) x^2 + (q_v delta)/(2lambda) x + T_w
$

$display(
  evaluated(T_max)_(x=delta/2) = T_w + (q_v delta)/(4lambda) \
  evaluated(q)_(x=0) = -lambda evaluated(dv(T, x))_(x=0) = -lambda C_1 = -(q_v delta)/2 \
  evaluated(q)_(x=delta) = -lambda evaluated(dv(T, x))_(x=delta) = (q_v delta)/2
)$

=== Теплопроводность плоской стенки при $q_v != 0$ с граничными условиями III рода

#v(1em)

$
  dv(T, x, 2) + q_V/lambda = 0
$

Граничные условия III рода
$
  evaluated((-lambda dv(T, x)))_(x=cases(0, delta)) = evaluated(alpha [T_w - T_f])_(x=cases(0, delta))
$

Найдем коэффициент $C_1$ в уравнении
$
  dv(T, x) = -q_V/lambda x + C_1
$

$display(evaluated(dv(T, x))_(x=delta/2) = 0 => C_1 = (q_v delta)/(2lambda))$

$
  dv(T, x) = -q_v/lambda x + (q_v delta)/(2lambda)
$

$display(
  evaluated(dv(T, x))_(x=delta) = -q_v/lambda delta + (q_v delta)/(2lambda) = -(q_v delta)/(2lambda) \
  evaluated((-lambda dv(T, x)))_(x=delta) = alpha [T_w (delta) - T_f] \
  T_w (delta) = T_f + (q_v delta)/(2lambda) \
  T_w (delta) = -(q_v delta^2)/(2lambda) + (q_v delta^2)/(2lambda) + C_2 => C_2 = T_w (delta) = T_f + (q_v delta)/(2lambda)
)$

$
  T(x) = -q_v/(2lambda) x^2 + (q_v delta)/(2lambda) x + (q_v delta)/(2lambda) + T_f
$

$display(evaluated(T_w)_(x=cases(0, delta)) = T_f + (q_v delta)/(2lambda))$

$
  T_max = evaluated(T)_(x=delta/2) = T_f + (q_v delta^2)/(8lambda) + (q_v delta)/(2alpha)
$

=== Теплопроводность однослойной цилиндрической стенки с граничными условиями I рода

#v(1em)

Дана цилиндрическая стенка (труба) с внутренним диаметром $d_1 = 2r_1$ и внешним диаметром $d_2 = 2r_2$. Объемные тепловыделения отсутствуют

#grid(
  columns: (1fr, 3.5fr),
  column-gutter: 1em,
  [
    #figure(
      image("source-figures/lect8-1.png"),
    )
  ],
  [
    $
      nabla^2 T = 0 <=> pdv(T, r, 2) + 1/r pdv(T, r) + 1/r^2 pdv(T, phi, 2) + pdv(T, z) = 0
    $

    Функция температуры будет иметь вид $T = T(r)$.

    ДУ теплопроводности принимает вид

    $
      dv(T, r, 2) + 1/r dv(T, r) = 0
    $

    Подставим $display(u = dv(T, r))$

    $display(
      dv(u, r) + u/r = 0 <=> (dif u)/u = -(dif r)/r <=> ln u = -ln z + ln C <=> u = C_1/r \
      dv(T, r) = C_1/r \
    )$
  ],
)

$display(
  q = -lambda dv(T, r) ~ C_1/r \
  Q = const = q dot F \
  F = 2pi r L ~ r => q ~ 1/r \
  dif T = C_1 (dif r)/r => T(r) = C_1 ln r + C_2 \
  cases(
    T(r_1) = T_w_1 = C_1 ln r_1 + C_2,
    T(r_2) = T_w_2 = C_1 ln r_2 + C_2,
  ) => cases(
    C_1 = (T_w_1 - T_w_2)/(ln r_1/r_2),
    C_2 = (T_w_2 ln r_1 - T_w_1 ln r_2)/(ln r_1/r_2)
  )
)$

$
  T(r) = (T_w_1 ln(r_2/r) + T_w_2 ln(r/r_1))/(ln r_2/r_1)
$

$display(q = -lambda dv(T, r) = -lambda C_1/r = (lambda (T_w_1 - T_w_2))/(r ln r_1/r_2))$

Тепловой поток
$
  Q = q F = (lambda (T_w_1 - T_w_2))/(r ln r_1/r_2) dot 2pi r L = (pi (T_w_1 - T_w_2) L)/(1/(2lambda) ln(r_2/r_1))
$

Линейный тепловой поток
$
  Q_L = Q/L = (pi (T_w_1 - T_w_2))/(1/(2lambda) ln(r_2/r_1))
$

Линейное термическое сопротивление
$
  R_L_lambda = 1/(2lambda) ln(r_2/r_1) space [(м dot К)/"Вт"]
$

=== Теплопроводность многослойной цилиндрической стенки с граничными условиями I рода

#v(1em)

#grid(
