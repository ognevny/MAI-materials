  $
    0 < epsilon = (E(T))/(E_0 (T)) < 1 , space epsilon_lambda = epsilon \
    E(T) = epsilon C_0 (T/100)^4, space 0 < C = epsilon C_0 < C_0
  $

+ #grid(
    columns: (4fr, 1fr),
