    $
      cases(
        Q_1 = R T_1 ln v_B/v_A,
        Q_2 = R T_2 ln v_C/v_D,
      ) => eta_t = 1 - T_2/T_1 => Q_2/Q_1 = T_2/T_1
    $
  ],
)

===== Необратимый цикл Карно

#v(1em)

$
  eta_(t"необр") < eta_(t"обр") \
  eta_(t"необр") = (Q_1 - Q_2)/Q_1 , space eta_(t"обр") = (T_1 - T_2)/T_1 => (Q_1 - Q_2)/Q_1 < (T_1 - T_2)/T_1
$

===== Обратимый цикл Карно

#v(1em)

$
  1 - Q_2/Q_1 = 1 - T_2/T_1 => Q_2/Q_1 = T_2/T_1,
$
где $display(Q_1/T_1 = Q_2/T_2)$ -- приведенные теплоты, для обратимого цикла Карно имеем

$
  Q_1/T_1 + Q_2/T_2 = 0 => sum Q/T = 0
$

В необратимом цикле Карно $display(sum Q/T < 0)$

