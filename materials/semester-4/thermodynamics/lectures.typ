    $
      l_0 & = (w_2^2 - w_1^2)/2 = Q - (i_2 - i_1) \
      l_0 & = i_1 - i_2 \
      l_0 & = c (T_1 - T_2), space c = k/(k-1) R \
      l_0 & = k/(k-1) R (T_1 - T_2) = k/(k-1) (p_1 v_1 - p_2 v_2)
    $

    Работа расширения $ L = 1/(k-1) (p_1 v_1 - p_2 v_2) $

    Работа проталкивания
    $
      l = (p_2 v_2 - p_1 v_1)
    $
  ],
