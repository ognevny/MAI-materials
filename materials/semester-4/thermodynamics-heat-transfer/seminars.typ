$display(
  Re = (w d)/nu = (20 dot 2 dot 10^(-3))/(0.824 dot 10^(-6)) approx 48500 => "турбулентное течение" \
  Nu_f = 0.021 dot Re_f^0.8 Pr_f^0.43 dot (Pr_f/Pr_w)^0.25 \
